# Free LLM — get a key at https://console.groq.com
VITE_GROQ_API_KEY=your_groq_api_key_here

# YouTube search — get a key at https://console.cloud.google.com
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# Spotify — create an app at https://developer.spotify.com/dashboard
# Redirect URIs in the dashboard must match EXACTLY (protocol, host, no trailing slash):
#   Local:  http://127.0.0.1:5173
#   Prod:   https://antsn.vercel.app  (and any custom domain you use)
# Vercel env (Production): set all three below, then redeploy
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_SPOTIFY_REDIRECT_URI=https://antsn.vercel.app/
# Server-only (Vercel → Settings → Environment Variables, not VITE_):
# Enable "Client secret" in Spotify dashboard → copy here for reliable prod search
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
